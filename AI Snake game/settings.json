    "ppo_gae_lambda": 0.95,
    "ppo_ent_coef": 0.05,  // Boost exploration
    "ppo_vf_coef": 0.5,
    "ppo_batch_size": 64,
    "ppo_max_grad_norm": 0.5,
    "use_epsilon": true
