    "batch_size": 64,
    "lr": 0.0005,  // Higher for quick early adaptation
    "gamma": 0.99,
    "grid_size": 40,
    "channels": 4,
    "file_name": "model.pth",
    "render_ui": false,
    "epsilon_start": 0.9,
